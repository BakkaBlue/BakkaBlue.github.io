{
  "name": "idle-realms",
  "private": true,
  "version": "0.1.0",
  "description": "Idle Realms · 放置王国 — 基于时间累积的多技能放置类 RPG",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "vue-tsc -b --noEmit",
    "verify": "vue-tsc -b --noEmit && vite build && vitest run",
    "server": "powershell -ExecutionPolicy Bypass -File server.ps1 -Action start",
    "server:stop": "powershell -ExecutionPolicy Bypass -File server.ps1 -Action stop",
    "server:restart": "powershell -ExecutionPolicy Bypass -File server.ps1 -Action restart"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
